# TalkHub CRM — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# Generate secure values with:
#   openssl rand -base64 32    (for passwords)
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"  (for SECRET_KEY)
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  (for FERNET_KEY)

# PostgreSQL superuser password (REQUIRED)
CRM_POSTGRES_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD

# Django secret key (REQUIRED)
CRM_SECRET_KEY=CHANGE_ME_GENERATE_DJANGO_SECRET_KEY

# Database application user password - used by crm_user for RLS (REQUIRED)
CRM_DB_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD

# SMTP password for Titan Email (REQUIRED for email sending)
CRM_SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD

# Default admin password - first boot only (REQUIRED)
CRM_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# MinIO S3 credentials (shared MinIO service)
CRM_S3_BUCKET=talkhub-crm
CRM_S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS_KEY
CRM_S3_SECRET_KEY=CHANGE_ME_S3_SECRET_KEY
CRM_S3_ENDPOINT=https://bucketss3.talkhub.me

# Google OAuth (optional — leave empty to disable)
CRM_GOOGLE_CLIENT_ID=
CRM_GOOGLE_CLIENT_SECRET=

# Fernet encryption key for field-level encryption (REQUIRED)
CRM_FERNET_KEY=CHANGE_ME_GENERATE_FERNET_KEY

# Sentry DSN for error tracking (optional — leave empty to disable)
CRM_SENTRY_DSN=
CRM_SENTRY_ENVIRONMENT=prod
