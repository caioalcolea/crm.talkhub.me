# TalkHub CRM — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# PostgreSQL superuser password
CRM_POSTGRES_PASSWORD=

# Django secret key (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
CRM_SECRET_KEY=

# Database application user password (used by crm_user for RLS)
CRM_DB_PASSWORD=

# SMTP password (Titan Email)
CRM_SMTP_PASSWORD=

# Default admin password (first boot only)
CRM_ADMIN_PASSWORD=

# MinIO S3 credentials
CRM_S3_BUCKET=talkhub-crm
CRM_S3_ACCESS_KEY=
CRM_S3_SECRET_KEY=
CRM_S3_ENDPOINT=https://s3.talkhub.me

# Google OAuth (optional)
CRM_GOOGLE_CLIENT_ID=
CRM_GOOGLE_CLIENT_SECRET=

# Fernet encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CRM_FERNET_KEY=

# Sentry DSN (optional)
CRM_SENTRY_DSN=
CRM_SENTRY_ENVIRONMENT=prod

# Redis password
CRM_REDIS_PASSWORD=
